# Database connection string for PostgreSQL
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE
# Local: postgresql://postgres:password@localhost:5432/hostel_allocation
# Neon Cloud: postgresql://user:password@endpoint.neon.tech/database_name
DATABASE_URL="postgresql://postgres:password@localhost:5432/hostel_allocation"

# SMTP Configuration for Email OTP (Required for production)
# These environment variables are needed to send OTP via email
SMTP_HOST="smtp.gmail.com"
SMTP_PORT="587"
SMTP_USER="your-email@gmail.com"
SMTP_PASSWORD="your-app-password"
SMTP_SECURE="false"
SMTP_FROM_EMAIL="your-email@gmail.com"

# For detailed setup instructions, see SETUP_GUIDE.md
