# Database Connection (Neon PostgreSQL)
# For local development, you can use a local PostgreSQL instance
# For production, use your Neon connection string
DATABASE_URL="postgresql://username:password@localhost:5432/teacoffee_slips?schema=public"

# Gmail SMTP Configuration for OTP emails
# SMTP_USER: Your Gmail address (e.g., yourname@gmail.com)
# SMTP_PASS: Gmail App Password (NOT your regular password)
#   - Go to https://myaccount.google.com/apppasswords
#   - Generate a new App Password for "Mail"
#   - Use that 16-character password here
SMTP_USER="your-email@gmail.com"
SMTP_PASS="your-app-password"

# Optional: SMTP Configuration (defaults to Gmail)
SMTP_HOST="smtp.gmail.com"
SMTP_PORT="587"
